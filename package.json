{
  "name": "conectamos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run db:ensure-vendor-profiles && npm run prisma:generate && next build",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "db:push": "npx prisma db push",
    "db:ensure-vendor-profiles": "npx prisma db execute --file scripts/ensure-vendor-profiles.sql",
    "seed:initial": "npx prisma db execute --file scripts/seed-initial-data.sql",
    "prisma:generate": "npx prisma generate",
    "lint": "eslint"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@types/pdfkit": "^0.17.6",
    "next": "16.2.3",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
